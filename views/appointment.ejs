    <!-- ===== Appointment Section ===== -->
    <section class="appointment-section">

        <div class="appointment-container">

            <h1>Book an Appointment</h1><br>
            <p>Fill the form below and our team will contact you shortly.</p><br>

            <!-- Appointment Form -->
            <form action="/appointment" method="POST" class="appointment-form">

                <!-- Patient Name -->
                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" name="name" placeholder="Enter your full name" required>
                </div><br>

                <!-- Email -->
                <div class="form-group">
                    <label>Email Address</label>
                    <input type="email" name="email" placeholder="Enter your email" required>
                </div><br>

                <!-- Phone -->
                <div class="form-group">
                    <label>Phone Number</label>
                    <input type="tel" name="phone" placeholder="Enter your phone number" required>
                </div><br>

                <!-- Doctor Select -->
                <div class="form-group">
                    <label>Select Doctor</label>
                    <select name="doctor" required>
                        <option value="">-- Choose Doctor --</option>
                        <option>Dr. Abhishek Dwivedi (Classical Homeopath)</option>
                        <option>Dr. Vaishali Bhargava (Dermentologist)</option>
                        
                    </select>
                </div><br>
                 <div>
                     <label>Select Service Mode </label>
                    <select name="doctor" required>
                        <option value="">-- Choose Service Mode --</option>
                        <option>Offline</option>
                        <option>Online</option>
                         </select>
                 </div><br>

                <!-- Date -->
                <div class="form-group">
                    <label>Appointment Date</label>
                    <input type="date" name="date" required>
                </div><br>

                <!-- Time -->
                <div class="form-group">
                    <label>Preferred Time</label>
                    <input type="time" name="time" required>
                </div><br>

                <!-- Message -->
                <div class="form-group">
                    <label>Message</label>
                    <textarea name="message" rows="4" placeholder="Write your problem..."></textarea>
                </div><br>

                <!-- Submit Button -->
                <button type="submit" class="btn">
                    Book Appointment
                </button><br>

            </form>

        </div>

    </section>



