    <!--This code in script is for menu bar when used in mobile when we click on that menu appears 
    and when again click menu disappears...selecting menu-toggle and nav-links...navLinks.classList.toggle("active");
    This line does the magic:
If .active is not present → it adds it
If .active exists → it removes it-->
    <script>
const toggle = document.querySelector(".menu-toggle");
const navLinks = document.querySelector(".nav-links");

toggle.addEventListener("click", () => { 
    navLinks.classList.toggle("active");
});
</script>


